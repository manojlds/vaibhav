// vaibhav zellij.kdl — mobile-friendly defaults
// Install (done by setup-desktop.sh):
//   ~/.config/zellij/config.kdl -> ~/projects/vaibhav/zellij.kdl

// Better rendering on narrow Termux/mobile screens
simplified_ui true
pane_frames false
default_layout "compact"
show_startup_tips false
show_release_notes false

// Keep mouse/touch interactions enabled
mouse_mode true

// Web client backspace/modifier behavior is more stable without kitty keyboard protocol.
support_kitty_keyboard_protocol false

// Convenience keys similar to tmux mobile workflow
keybinds {
    shared_except "locked" {
        bind "Alt n" { GoToNextTab; }
        bind "Alt p" { GoToPreviousTab; }
        bind "Alt s" {
            Run "bash" "-lc" "$HOME/bin/vaibhav-switcher --backend zellij" {
                floating true
                close_on_exit true
                width "95%"
                height "80%"
                x "2%"
                y "10%"
            }
        }

        // Guard rails for mobile keyboards: disable default tab-move chords if present.
        bind "Alt i" { SwitchToMode "normal"; }
        bind "Alt o" { SwitchToMode "normal"; }
    }

    // Prevent Ctrl+H from entering move mode on configs that still include default bindings.
    shared_except "locked" "move" {
        bind "Ctrl h" { SwitchToMode "normal"; }
    }
}
