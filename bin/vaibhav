#!/usr/bin/env bash
# vaibhav - Project session manager for AI coding tools over tmux
# Usage:
#   vaibhav init              - Interactive setup (creates ~/.config/vaibhav/config)
#   vaibhav list              - List all registered projects and active sessions
#   vaibhav refresh           - Detect desktop LAN IP and save VAIBHAV_LAN_HOST
#   vaibhav <name>            - Attach/create project session
#   vaibhav <name> <tool>     - Attach/create session and launch an AI tool
#   vaibhav add <name> <path> - Register a new project
#   vaibhav remove <name>     - Unregister a project
#   vaibhav scan [dir]        - Auto-register all projects under a directory

set -euo pipefail

VAIBHAV_VERSION="0.9.7"

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/vaibhav"
CONFIG_FILE="$CONFIG_DIR/config"
PROJECTS_FILE="$CONFIG_DIR/projects"

# Resolve lib directory relative to this script (follows symlinks)
VAIBHAV_LIB="$(cd "$(dirname "$(readlink -f "$0")")/../lib" && pwd)"

# --- Load config if it exists ---
if [[ -f "$CONFIG_FILE" ]]; then
    # shellcheck source=/dev/null
    source "$CONFIG_FILE"
fi

# --- Source library modules ---
# shellcheck source=../lib/ui.sh
source "$VAIBHAV_LIB/ui.sh"
# shellcheck source=../lib/mux.sh
source "$VAIBHAV_LIB/mux.sh"

# --- Resolve multiplexer backend ---
# shellcheck disable=SC2034 # used by sourced lib modules
VAIBHAV_MULTIPLEXER="tmux"
# shellcheck disable=SC2034 # used by sourced lib modules
if command -v tmux &>/dev/null; then
    VAIBHAV_MUX_BACKEND="tmux"
else
    VAIBHAV_MUX_BACKEND=""
fi

# --- Remote dispatch (may exec into SSH/mosh and never return) ---
# shellcheck source=../lib/remote.sh
source "$VAIBHAV_LIB/remote.sh"

# --- Local mode below this point ---
VAIBHAV_PROJECTS_DIR="${VAIBHAV_PROJECTS_DIR:-}"

mkdir -p "$CONFIG_DIR"
touch "$PROJECTS_FILE"

# --- Source remaining modules (only needed locally) ---
# shellcheck source=../lib/init.sh
source "$VAIBHAV_LIB/init.sh"
# shellcheck source=../lib/projects.sh
source "$VAIBHAV_LIB/projects.sh"
# shellcheck source=../lib/setup.sh
source "$VAIBHAV_LIB/setup.sh"
# shellcheck source=../lib/doctor.sh
source "$VAIBHAV_LIB/doctor.sh"
# shellcheck source=../lib/devserver.sh
source "$VAIBHAV_LIB/devserver.sh"

# Main dispatch
case "${1:-}" in
    ""|help|-h|--help)
        show_usage
        ;;
    version|-v|--version)
        echo "vaibhav $VAIBHAV_VERSION"
        ;;
    init)
        init_config
        ;;
    list|ls)
        list_projects
        ;;
    add)
        if [[ $# -lt 3 ]]; then
            echo -e "${RED}Usage:${NC} vaibhav add <name> <path>"
            exit 1
        fi
        add_project "$2" "$3"
        ;;
    kill)
        if [[ $# -lt 2 ]]; then
            echo -e "${RED}Usage:${NC} vaibhav kill <name> [window]"
            exit 1
        fi
        kill_project "$2" "${3:-}"
        ;;
    remove|rm)
        if [[ $# -lt 2 ]]; then
            echo -e "${RED}Usage:${NC} vaibhav remove <name>"
            exit 1
        fi
        remove_project "$2"
        ;;
    scan)
        scan_projects "${2:-}"
        ;;
    web)
        shift
        show_web_status "$@"
        ;;
    doctor)
        show_doctor "${@:2}"
        ;;
    refresh)
        run_refresh
        ;;
    setup)
        setup_termux "${@:2}"
        ;;
    update)
        if [[ -n "$VAIBHAV_DESKTOP_HOST" ]] && ! vaibhav_is_current_host_desktop; then
            update_termux
            # Run setup with the newly updated vaibhav to apply any new setup steps
            "$HOME/bin/vaibhav" setup --post-update || true
            # Also update desktop unless --local flag is set
            skip_desktop=false
            for arg in "$@"; do
                [[ "$arg" == "--local" ]] && skip_desktop=true
            done
            if [[ "$skip_desktop" == "false" ]]; then
                update_desktop_remote
            fi
        else
            update_desktop
        fi
        ;;
    share)
        shift
        share_files "$@"
        ;;
    dev)
        shift
        dev_dispatch "$@"
        ;;
    ralph)
        shift
        SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
        exec "$SCRIPT_DIR/vaibhav-ralph" "$@"
        ;;
    *)
        open_project "$1" "${2:-}"
        ;;
esac
