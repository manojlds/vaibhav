#!/usr/bin/env bash
# vaibhav-switcher — fuzzy project/session switcher for tmux and zellij
# Active sessions: switch / kill. Inactive projects: pick a tool and start.
# Intended to be launched from multiplexer keybindings (Alt+s).
set -euo pipefail

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/vaibhav"
PROJECTS_FILE="$CONFIG_DIR/projects"

BACKEND=""
if [[ "${1:-}" == "--backend" ]]; then
    if [[ $# -lt 2 ]]; then
        echo "Error: --backend requires tmux or zellij" >&2
        exit 1
    fi
    BACKEND="$2"
    shift 2
fi

if [[ -z "$BACKEND" ]]; then
    if [[ -n "${TMUX:-}" ]]; then
        BACKEND="tmux"
    elif [[ -n "${ZELLIJ:-}" ]]; then
        BACKEND="zellij"
    else
        echo "Error: not inside tmux or zellij" >&2
        exit 1
    fi
fi

if [[ "$BACKEND" != "tmux" && "$BACKEND" != "zellij" ]]; then
    echo "Error: unsupported backend '$BACKEND'" >&2
    exit 1
fi

notify() {
    local msg="$1"
    case "$BACKEND" in
        tmux)
            tmux display-message "$msg" || true
            ;;
        zellij)
            echo "$msg" >&2
            ;;
    esac
}

if ! command -v fzf >/dev/null 2>&1; then
    notify "fzf not found. Install with: sudo apt install fzf"
    exit 0
fi

if [[ ! -f "$PROJECTS_FILE" ]]; then
    notify "No projects file. Run: vaibhav init"
    exit 0
fi

list_sessions() {
    case "$BACKEND" in
        tmux)
            tmux list-sessions -F '#{session_name}' 2>/dev/null || true
            ;;
        zellij)
            zellij list-sessions --no-formatting 2>/dev/null |
                awk '
                    /^[[:space:]]*$/ { next }
                    /No active sessions/ { next }
                    /\(EXITED/ { next }
                    { print $1 }
                ' || true
            ;;
    esac
}

list_targets() {
    local session="$1"
    case "$BACKEND" in
        tmux)
            tmux list-windows -t "$session" -F '#{window_name}' 2>/dev/null | tr '\n' ' ' | sed 's/ $//'
            ;;
        zellij)
            zellij --session "$session" action query-tab-names 2>/dev/null | tr '\n' ' ' | sed 's/ $//'
            ;;
    esac
}

current_session_name() {
    case "$BACKEND" in
        tmux)
            tmux display-message -p '#{session_name}' 2>/dev/null || true
            ;;
        zellij)
            printf '%s\n' "${ZELLIJ_SESSION_NAME:-}"
            ;;
    esac
}

is_active_session() {
    local session="$1"
    list_sessions | grep -qx "$session" 2>/dev/null
}

kill_session() {
    local session="$1"
    case "$BACKEND" in
        tmux)
            tmux kill-session -t "$session"
            ;;
        zellij)
            zellij kill-session "$session"
            ;;
    esac
}

detach_current() {
    case "$BACKEND" in
        tmux)
            tmux detach-client
            ;;
        zellij)
            zellij action detach
            ;;
    esac
}

switch_session() {
    local session="$1"
    local current_session="$2"

    case "$BACKEND" in
        tmux)
            tmux switch-client -t "$session"
            ;;
        zellij)
            [[ "$session" == "$current_session" ]] && return 0
            (
                sleep 0.15
                env -u ZELLIJ -u ZELLIJ_SESSION_NAME zellij attach "$session"
            ) >/dev/null 2>&1 &
            zellij action detach
            ;;
    esac
}

start_project() {
    local project_name="$1"
    local tool="${2:-}"

    case "$BACKEND" in
        tmux)
            if [[ -n "$tool" ]]; then
                tmux run-shell -b "$HOME/bin/vaibhav '$project_name' '$tool'"
            else
                tmux run-shell -b "$HOME/bin/vaibhav '$project_name'"
            fi
            ;;
        zellij)
            (
                sleep 0.15
                if [[ -n "$tool" ]]; then
                    env -u ZELLIJ -u ZELLIJ_SESSION_NAME "$HOME/bin/vaibhav" "$project_name" "$tool"
                else
                    env -u ZELLIJ -u ZELLIJ_SESSION_NAME "$HOME/bin/vaibhav" "$project_name"
                fi
            ) >/dev/null 2>&1 &
            zellij action detach
            ;;
    esac
}

build_entries() {
    local current_session="$1"

    declare -A active_sessions=()
    while IFS= read -r session; do
        [[ -z "$session" ]] && continue
        active_sessions["$session"]="$(list_targets "$session")"
    done < <(list_sessions | sort)

    for session in $(printf '%s\n' "${!active_sessions[@]}" | sort); do
        local targets="${active_sessions[$session]}"
        if [[ -n "$current_session" && "$session" == "$current_session" ]]; then
            echo "● $session  [$targets]"
        else
            echo "▸ $session  [$targets]"
        fi
    done

    while IFS='=' read -r name path; do
        [[ -z "$name" || "$name" == \#* ]] && continue
        if [[ -z "${active_sessions[$name]+_}" ]]; then
            echo "  $name  ($path)"
        fi
    done < "$PROJECTS_FILE"

    echo ""
    echo "⏏ Detach"
    echo "✕ Kill all sessions"
}

pick_tool() {
    local project_name="$1"
    local tools=("shell (no tool)" "amp" "claude" "codex" "opencode" "pi")

    printf '%s\n' "${tools[@]}" | \
        fzf --header=" Start $project_name — pick a tool" \
            --prompt=" tool> " \
            --reverse \
        || true
}

while true; do
    current_session="$(current_session_name)"
    entries="$(build_entries "$current_session")"

    if [[ -z "$entries" ]]; then
        notify "No projects found"
        exit 0
    fi

    result=$(printf '%s\n' "$entries" | \
        fzf --header=" vaibhav  │  Enter: switch/start  │  Ctrl-X: kill session" \
            --prompt=" project> " \
            --reverse \
            --no-sort \
            --cycle \
            --expect=ctrl-x \
        || true)

    [[ -z "$result" ]] && exit 0

    key=$(head -1 <<< "$result")
    selected=$(tail -1 <<< "$result")
    [[ -z "$selected" ]] && exit 0

    if [[ "$selected" == "⏏ Detach" ]]; then
        detach_current
        exit 0
    fi

    if [[ "$selected" == "✕ Kill all sessions" ]]; then
        killed=0
        while IFS= read -r session; do
            [[ -z "$session" ]] && continue
            if [[ -n "$current_session" && "$session" == "$current_session" ]]; then
                continue
            fi
            if kill_session "$session" 2>/dev/null; then
                killed=$((killed + 1))
            fi
        done < <(list_sessions)
        notify "Killed $killed session(s)${current_session:+ (kept current: $current_session)}"
        exit 0
    fi

    project_name=$(printf '%s\n' "$selected" | sed -E 's/^[[:space:]●▸]*//' | awk '{print $1}')
    [[ -z "$project_name" ]] && exit 0

    is_active=false
    is_active_session "$project_name" && is_active=true

    if [[ "$key" == "ctrl-x" ]]; then
        if [[ "$is_active" == "true" ]]; then
            if [[ -n "$current_session" && "$project_name" == "$current_session" ]]; then
                notify "Cannot kill current session"
                sleep 0.5
            else
                kill_session "$project_name" || true
            fi
        fi
        continue
    fi

    if [[ "$is_active" == "true" ]]; then
        switch_session "$project_name" "$current_session"
        exit 0
    fi

    tool_choice="$(pick_tool "$project_name")"
    [[ -z "$tool_choice" ]] && exit 0

    if [[ "$tool_choice" == "shell (no tool)" ]]; then
        start_project "$project_name"
    else
        start_project "$project_name" "$tool_choice"
    fi
    exit 0
done
