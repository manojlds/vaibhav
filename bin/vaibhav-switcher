#!/usr/bin/env bash
# vaibhav-switcher — fuzzy project/session switcher for vaibhav multiplexers
# Active sessions: switch / kill. Inactive projects: pick a tool and start.
# Intended to be launched from multiplexer keybindings (Alt+s).
set -euo pipefail

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/vaibhav"
CONFIG_FILE="$CONFIG_DIR/config"
PROJECTS_FILE="$CONFIG_DIR/projects"

if [[ -f "$CONFIG_FILE" ]]; then
    # shellcheck source=/dev/null
    source "$CONFIG_FILE"
fi

mux_backend=""
if [[ -n "${HERDR_ENV:-}" || -n "${HERDR_ACTIVE_WORKSPACE_ID:-}" || -n "${HERDR_WORKSPACE_ID:-}" ]]; then
    mux_backend="herdr"
elif [[ -n "${TMUX:-}" ]]; then
    mux_backend="tmux"
elif [[ "${VAIBHAV_MULTIPLEXER:-}" == "herdr" ]] && command -v herdr >/dev/null 2>&1; then
    mux_backend="herdr"
fi

if [[ -z "$mux_backend" ]]; then
    echo "Error: not inside a supported multiplexer" >&2
    exit 1
fi

notify() {
    local msg="$1"
    case "$mux_backend" in
        tmux)
            tmux display-message "$msg" || true
            ;;
        herdr)
            herdr notification show "vaibhav" --body "$msg" >/dev/null 2>&1 || printf '%s\n' "$msg" >&2
            ;;
    esac
}

if ! command -v fzf >/dev/null 2>&1; then
    notify "fzf not found. Install with: sudo apt install fzf"
    exit 0
fi

if [[ ! -f "$PROJECTS_FILE" ]]; then
    notify "No projects file. Run: vaibhav init"
    exit 0
fi

list_sessions() {
    case "$mux_backend" in
        tmux)
            tmux list-sessions -F '#{session_name}' 2>/dev/null || true
            ;;
        herdr)
            herdr workspace list 2>/dev/null \
                | grep -Eo '"label":"[^"]+"' \
                | sed 's/^"label":"//; s/"$//' || true
            ;;
    esac
}

list_targets() {
    local session="$1"
    case "$mux_backend" in
        tmux)
            tmux list-windows -t "$session" -F '#{window_name}' 2>/dev/null | tr '\n' ' ' | sed 's/ $//'
            ;;
        herdr)
            local workspace_id
            workspace_id="$(_herdr_workspace_id_by_label "$session")"
            [[ -n "$workspace_id" ]] || return 0
            herdr tab list --workspace "$workspace_id" 2>/dev/null \
                | grep -Eo '"label":"[^"]+"' \
                | sed 's/^"label":"//; s/"$//' \
                | tr '\n' ' ' \
                | sed 's/ $//' || true
            ;;
    esac
}

list_herdr_targets_by_workspace_id() {
    local workspace_id="$1"
    [[ -n "$workspace_id" ]] || return 0
    herdr tab list --workspace "$workspace_id" 2>/dev/null \
        | grep -Eo '"label":"[^"]+"' \
        | sed 's/^"label":"//; s/"$//' \
        | tr '\n' ' ' \
        | sed 's/ $//' || true
}

current_session_name() {
    case "$mux_backend" in
        tmux)
            tmux display-message -p '#{session_name}' 2>/dev/null || true
            ;;
        herdr)
            printf '%s\n' "${HERDR_ACTIVE_WORKSPACE_ID:-${HERDR_WORKSPACE_ID:-}}"
            ;;
    esac
}

herdr_workspace_records() {
    herdr workspace list 2>/dev/null \
        | tr '{' '\n' \
        | grep '"workspace_id":"' \
        | while IFS= read -r obj; do
            local label workspace_id
            label="$(sed -n 's/.*"label":"\([^"]*\)".*/\1/p' <<<"$obj")"
            workspace_id="$(sed -n 's/.*"workspace_id":"\([^"]*\)".*/\1/p' <<<"$obj")"
            [[ -n "$label" && -n "$workspace_id" ]] && printf '%s|%s\n' "$label" "$workspace_id"
        done
}

_herdr_workspace_id_by_label() {
    local label="$1"
    herdr workspace list 2>/dev/null \
        | tr '{' '\n' \
        | grep -F "\"label\":\"${label}\"" \
        | sed -n 's/.*"workspace_id":"\([^"]*\)".*/\1/p' \
        | head -1 || true
}

run_after_herdr_switcher_exits() {
    # Herdr closes the temporary command pane after this script exits. Delay
    # focus/open actions so that close does not restore the old workspace.
    if command -v setsid >/dev/null 2>&1; then
        # shellcheck disable=SC2016 # evaluated by the delayed shell
        setsid -f sh -c 'sleep 0.5; "$@"' sh "$@" >/dev/null 2>&1
    else
        # shellcheck disable=SC2016 # evaluated by the delayed shell
        nohup sh -c 'sleep 0.5; "$@"' sh "$@" >/dev/null 2>&1 &
    fi
}

is_active_session() {
    local session="$1"
    list_sessions | grep -qx "$session" 2>/dev/null
}

kill_session() {
    local session="$1"
    local workspace_id="${2:-}"
    case "$mux_backend" in
        tmux)
            tmux kill-session -t "$session"
            ;;
        herdr)
            workspace_id="${workspace_id:-$(_herdr_workspace_id_by_label "$session")}"
            workspace_id="${workspace_id//[[:space:]]/}"
            [[ -n "$workspace_id" ]] && herdr workspace close "$workspace_id" >/dev/null
            ;;
    esac
}

detach_current() {
    case "$mux_backend" in
        tmux)
            tmux detach-client
            ;;
        herdr)
            notify "Use Herdr detach: alt+d or prefix+q"
            ;;
    esac
}

switch_session() {
    local session="$1"
    local workspace_id="${2:-}"
    case "$mux_backend" in
        tmux)
            tmux switch-client -t "$session"
            ;;
        herdr)
            workspace_id="${workspace_id:-$(_herdr_workspace_id_by_label "$session")}"
            workspace_id="${workspace_id//[[:space:]]/}"
            if [[ -n "$workspace_id" ]]; then
                run_after_herdr_switcher_exits herdr workspace focus "$workspace_id"
            fi
            ;;
    esac
}

start_project() {
    local project_name="$1"
    local tool="${2:-}"

    case "$mux_backend" in
        tmux)
            if [[ -n "$tool" ]]; then
                tmux run-shell -b "$HOME/bin/vaibhav '$project_name' '$tool'"
            else
                tmux run-shell -b "$HOME/bin/vaibhav '$project_name'"
            fi
            ;;
        herdr)
            if [[ -n "$tool" ]]; then
                run_after_herdr_switcher_exits "$HOME/bin/vaibhav" "$project_name" "$tool"
            else
                run_after_herdr_switcher_exits "$HOME/bin/vaibhav" "$project_name"
            fi
            ;;
    esac
}

build_entries() {
    local current_session="$1"

    declare -A active_sessions=()
    if [[ "$mux_backend" == "herdr" ]]; then
        while IFS='|' read -r session workspace_id; do
            [[ -z "$session" || -z "$workspace_id" ]] && continue
            active_sessions["$session"]=1
            local targets marker
            targets="$(list_herdr_targets_by_workspace_id "$workspace_id")"
            marker="{$workspace_id}"
            if [[ -n "$current_session" && "$workspace_id" == "$current_session" ]]; then
                echo "● $session  [$targets]  $marker"
            else
                echo "▸ $session  [$targets]  $marker"
            fi
        done < <(herdr_workspace_records | sort)
    else
        while IFS= read -r session; do
            [[ -z "$session" ]] && continue
            active_sessions["$session"]="$(list_targets "$session")"
        done < <(list_sessions | sort)

        for session in $(printf '%s\n' "${!active_sessions[@]}" | sort); do
            local targets="${active_sessions[$session]}"
            if [[ -n "$current_session" && "$session" == "$current_session" ]]; then
                echo "● $session  [$targets]"
            else
                echo "▸ $session  [$targets]"
            fi
        done
    fi

    while IFS='=' read -r name path; do
        [[ -z "$name" || "$name" == \#* ]] && continue
        if [[ -z "${active_sessions[$name]+_}" ]]; then
            echo "  $name  ($path)"
        fi
    done < "$PROJECTS_FILE"

    if [[ "$mux_backend" == "tmux" ]]; then
        echo ""
        echo "✕ Kill all sessions"
        echo "⏏ Detach"
    fi
}

pick_tool() {
    local project_name="$1"
    local tools=("shell (no tool)" "amp" "claude" "codex" "opencode" "pi")

    printf '%s\n' "${tools[@]}" | \
        fzf --header=" Start $project_name — pick a tool" \
            --prompt=" tool> " \
            --reverse \
        || true
}

while true; do
    current_session="$(current_session_name)"
    entries="$(build_entries "$current_session")"

    if [[ -z "$entries" ]]; then
        notify "No projects found"
        exit 0
    fi

    result=$(printf '%s\n' "$entries" | \
        fzf --header=" vaibhav  │  Enter: switch/start  │  Ctrl-X: kill session" \
            --prompt=" project> " \
            --reverse \
            --no-sort \
            --cycle \
            --expect=ctrl-x \
        || true)

    [[ -z "$result" ]] && exit 0

    key=$(head -1 <<< "$result")
    selected=$(tail -1 <<< "$result")
    [[ -z "$selected" ]] && exit 0

    if [[ "$selected" == "⏏ Detach" ]]; then
        detach_current
        exit 0
    fi

    if [[ "$mux_backend" == "tmux" && "$selected" == "✕ Kill all sessions" ]]; then
        killed=0
        while IFS= read -r session; do
            [[ -z "$session" ]] && continue
            if [[ -n "$current_session" && "$session" == "$current_session" ]]; then
                continue
            fi
            if kill_session "$session" 2>/dev/null; then
                killed=$((killed + 1))
            fi
        done < <(list_sessions)
        notify "Killed $killed session(s)${current_session:+ (kept current: $current_session)}"
        exit 0
    fi

    active_workspace_id="$(sed -n 's/.*{\([^}]*\)}.*/\1/p' <<<"$selected")"
    project_name=$(printf '%s\n' "$selected" | sed -E 's/^[[:space:]●▸]*//' | awk '{print $1}')
    [[ -z "$project_name" ]] && exit 0

    is_active=false
    if [[ -n "$active_workspace_id" ]]; then
        is_active=true
    else
        is_active_session "$project_name" && is_active=true
    fi

    if [[ "$key" == "ctrl-x" ]]; then
        if [[ "$is_active" == "true" ]]; then
            if [[ -n "$active_workspace_id" && "$active_workspace_id" == "$current_session" ]]; then
                notify "Cannot close current workspace"
                sleep 0.5
            elif [[ -z "$active_workspace_id" && -n "$current_session" && "$project_name" == "$current_session" ]]; then
                notify "Cannot kill current session"
                sleep 0.5
            else
                kill_session "$project_name" "$active_workspace_id" || true
            fi
        fi
        continue
    fi

    if [[ "$is_active" == "true" ]]; then
        switch_session "$project_name" "$active_workspace_id"
        exit 0
    fi

    tool_choice="$(pick_tool "$project_name")"
    [[ -z "$tool_choice" ]] && exit 0

    if [[ "$tool_choice" == "shell (no tool)" ]]; then
        start_project "$project_name"
    else
        start_project "$project_name" "$tool_choice"
    fi
    exit 0
done
