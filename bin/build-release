#!/usr/bin/env bash
# build-release — Bundle a lean phone-only vaibhav script for Termux
# Inlines only the lib modules needed on the phone (remote dispatch,
# setup, update, doctor, init, ui). Skips mux.sh, projects.sh, and
# desktop-only functions (update_desktop) since they run on the desktop.
# Usage: bin/build-release
# Output: dist/vaibhav

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

SRC="$REPO_ROOT/bin/vaibhav"
LIB_DIR="$REPO_ROOT/lib"
DIST_DIR="$REPO_ROOT/dist"

mkdir -p "$DIST_DIR"

# Desktop-only functions to strip from inlined libs
DESKTOP_ONLY_FUNCTIONS=(update_desktop)

strip_functions() {
    # Remove named functions from stdin
    # Handles function_name() { ... } blocks (brace-matching)
    local input
    input=$(cat)
    for func in "${DESKTOP_ONLY_FUNCTIONS[@]}"; do
        input=$(echo "$input" | awk -v fname="$func" '
            $0 ~ "^" fname "\\(\\)" { skip=1; depth=0 }
            skip && /\{/ { depth += gsub(/\{/, "{") }
            skip && /\}/ { depth -= gsub(/\}/, "}"); if (depth <= 0) { skip=0; next } }
            skip { next }
            { print }
        ')
    done
    echo "$input"
}

{
    while IFS= read -r line; do
        # Skip the VAIBHAV_LIB resolution line
        if [[ "$line" == *'VAIBHAV_LIB="$(cd'* ]]; then
            continue
        fi

        # Inline source directives for lib modules
        if [[ "$line" =~ ^source\ \"\$VAIBHAV_LIB/(.+)\"$ ]]; then
            lib_file="${BASH_REMATCH[1]}"
            echo ""
            echo "# --- inlined: lib/$lib_file ---"
            # Strip shell directive; strip desktop-only functions from setup.sh
            if [[ "$lib_file" == "setup.sh" ]]; then
                sed '/^# shellcheck shell=bash$/d' "$LIB_DIR/$lib_file" | strip_functions
            else
                sed '/^# shellcheck shell=bash$/d' "$LIB_DIR/$lib_file"
            fi
            echo "# --- end: lib/$lib_file ---"
            continue
        fi

        # Skip shellcheck source= comments for lib modules
        if [[ "$line" =~ ^#\ shellcheck\ source=\.\./lib/ ]]; then
            continue
        fi

        # Skip section comments about sourcing
        if [[ "$line" == "# Resolve lib directory"* ]]; then
            continue
        fi
        if [[ "$line" == "# --- Source library modules ---" ]]; then
            continue
        fi
        if [[ "$line" == "# --- Source remaining modules"* ]]; then
            continue
        fi

        echo "$line"
    done < "$SRC"
} > "$DIST_DIR/vaibhav"

chmod +x "$DIST_DIR/vaibhav"

# Verify the bundled script is valid bash
if bash -n "$DIST_DIR/vaibhav"; then
    echo "✓ dist/vaibhav built ($(wc -l < "$DIST_DIR/vaibhav") lines)"
else
    echo "✗ dist/vaibhav has syntax errors" >&2
    exit 1
fi
